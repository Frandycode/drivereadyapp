# ── Docker ────────────────────────────────────────────────────────────────────
# Keep docker-compose.yml but ignore overrides
docker-compose.override.yml
docker-compose.local.yml

# ── Database & Migrations ─────────────────────────────────────────────────────
# Never ignore migrations/versions — they must be committed
*.sqlite
*.sqlite3
*.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Uploads & Media ───────────────────────────────────────────────────────────
backend/uploads/
backend/media/
sign-metadata/signs_output/

# ── CI / CD ───────────────────────────────────────────────────────────────────
# Keep .github/ directory but ignore local act runner cache
.act/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/

